# --- Groq (free, open-source LLMs) ---
# Get a FREE key (no credit card) at https://console.groq.com/keys
# Copy this file to .env.local and paste your key below.
GROQ_API_KEY=

# Optional model overrides (defaults shown). Any Groq-hosted open model works.
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL_FAST=llama-3.1-8b-instant

# --- Site URL (optional) ---
# Canonical base URL of your deployment. Used for canonical links, robots.txt,
# the sitemap, and the Open Graph card. Defaults to http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- GitHub repo (optional) ---
# owner/name shown by the landing page's GitHub button + star count.
# Defaults to sardorml/tailit; set this if you fork.
# NEXT_PUBLIC_GITHUB_REPO=your-name/your-repo

# --- GitHub token (optional) ---
# Authenticates the /api/stars call so the live star count isn't blocked by
# GitHub's 60-req/hr-per-IP limit (shared hosts like Render exhaust it fast).
# Any token works — a classic PAT with NO scopes is enough for a public repo.
# Create at https://github.com/settings/tokens. Leave unset for local dev.
# GITHUB_TOKEN=
