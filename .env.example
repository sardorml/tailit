# --- Groq (free, open-source LLMs) ---
# Get a FREE key (no credit card) at https://console.groq.com/keys
# Copy this file to .env.local and paste your key below.
GROQ_API_KEY=

# Optional model overrides (defaults shown). Any Groq-hosted open model works.
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL_FAST=llama-3.1-8b-instant

# --- Site URL (optional) ---
# Canonical base URL of your deployment. Used for canonical links, robots.txt,
# the sitemap, and the Open Graph card. Defaults to http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
